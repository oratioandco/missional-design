---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailLink from '../../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const principles = [
  {
    num: '01',
    title: 'Am tatsächlichen Verhalten gestalten, nicht an Erwartungen',
    body: 'Beiläufige und aufnehmende Formen zuerst — nicht ein angenommenes vertieftes Studium. Die vorherrschende Form ist reaktiv, situativ und kurz. Audio ist das am schnellsten wachsende Format. Lesepläne scheitern an einer Abbruchquote von 50 %. Eine Anwendung der nächsten Generation muss beiläufige und aufnehmende Nutzung zu vollwertigen Bestandteilen machen. Das verlangt Demut gegenüber dem tatsächlichen Verhalten der Menschen, statt ihnen Erwartungen aufzuerlegen.',
  },
  {
    num: '02',
    title: 'Verschiedene Zugänge zum Glauben eröffnen',
    body: 'Audio, Musik, kontemplative Stille und angeleitete Übung als eigenständige Formen — nicht als Beiwerk zum Lesen. Das Bibellesen ist nicht der einzige oder höchste Weg zu Gott. Menschen finden auf ganz unterschiedlichen Wegen Zugang zum Glauben; gute Gestaltung erkennt diese Vielfalt an — bis hin zu ökumenischer Weite — und begleitet Menschen darin. Auch die christliche Tradition kennt diese Bandbreite seit jeher.',
  },
  {
    num: '03',
    title: 'Der Konsum-Spiritualität widerstehen',
    body: 'Echte Auseinandersetzung mit der Tradition statt geistlicher Wohlfühl-Selbstbedienung. Offenlegen, woher eine Übung stammt; Tiefe statt Stöbern; gemeinschaftliche Verbindlichkeit. Traditionen benennen (ignatianisch, benediktinisch, franziskanisch, orthodox). Zur längeren Treue zu einer einzelnen Übung ermutigen statt zum täglichen Hineinschnuppern — keine Echokammern, kein Spiritualitäts-Baukasten.',
  },
  {
    num: '04',
    title: 'Niemals ein Ersatz für Gemeinde und Gemeinschaft',
    body: 'Glaube ist nicht privat; er wird in Gemeinschaft gelebt. Eine geistliche Anwendung darf niemals zum Ersatz für die Gemeinde und für echte Gemeinschaft werden. Das heißt nicht, dass sie „Gemeinschaftsfunktionen" anbieten muss — es heißt, dass sie Menschen nicht in Filterblasen und Selbstisolation führen darf. Übung, abgeschnitten von einer Gemeinschaft aus Menschen, driftet zum Konsum; gute Gestaltung verweist immer wieder zurück auf die leibhaftige Gemeinschaft.',
  },
  {
    num: '05',
    title: 'Brücken zur Gemeinschaft bauen, ohne sie zur Bedingung zu machen',
    body: 'Suchenden Menschen kann man nicht einfach sagen, sie sollten „eine Gemeinde finden". Baue Brücken, stelle keine Vorbedingungen. Jemand darf allein beginnen, einen geistlichen Rhythmus finden und von dort aus zu leibhaftiger Gemeinschaft hinwachsen. Das Ziel ist immer die echte Gemeinschaft — die Anwendung ist die Brücke, niemals das Ziel.',
  },
  {
    num: '06',
    title: 'Gnade und Freiheit statt Druck und Schuld',
    body: 'Dies ist eine bewusste Reaktion auf Mechaniken, die das geistliche Leben in ein Spiel oder eine Leistungsschau verwandeln, und auf andere Anreize zur Aufmerksamkeitsbindung, die Menschen ungefragt übergestülpt werden. Tagesserien, Scham-Auslöser, sozialer Vergleich — sie erzeugen Druck und Schuld, nicht die Gnade und Freiheit, die Christus verspricht. Schon ein Leseplan, der tägliches Lesen erwartet und einem Menschen dann sagt, er sei „im Rückstand", tut genau das. Eine Linie gilt: Der Mensch wählt Werkzeuge für das eigene Wachstum; die Plattform setzt niemals Mechaniken für die eigene Nutzerbindung ein. Und vertraue dem Inhalt — was wirklich relevant ist, braucht keine künstliche Verstärkung, damit Menschen wiederkommen.',
  },
  {
    num: '07',
    title: 'Aus dem eigenen Kontext gestalten, nicht aus übernommenen Mustern',
    body: 'Übernimm nicht blind die Mechaniken und Annahmen aus dem Silicon Valley oder von gerade dominierenden Anwendungen. Setze dich ernsthaft und konkret mit deiner eigenen Zielgruppe und ihrem Kontext auseinander. Europa ist nur ein Beispiel: Vieles, was in amerikanischen Produkten selbstverständlich ist — rund um Datenschutz, rund um eine nachchristliche Kultur, rund um das, was ein Nutzer angeblich erwartet — ist hier deutlich weniger relevant. Eine von Grund auf datenschutzfreundliche Architektur, Gastfreundschaft gegenüber vielen Traditionen, die Datenschutz-Grundverordnung als Bekenntnis zur Würde. Doch das ist das Beispiel, nicht das Prinzip. Das Prinzip lautet: Kontext ist nicht verhandelbar.',
  },
  {
    num: '08',
    title: 'Ehrlich wissen, wem man dient',
    body: 'Auch das verlangt Reflexion. Welchen Menschen — an welchem Punkt ihres christlichen Weges — hilfst du tatsächlich? Das heißt nicht, nur Suchenden oder Skeptikern zu dienen. Es heißt, konkret und ehrlich transparent zu sein: bei der Frage, wen du erreichen willst, und ebenso bei der Frage, wen du mit den momentanen Inhalten und Funktionen wirklich erreichen kannst. Menschen stehen in sehr unterschiedlichen geistlichen Situationen; benenne die deine, statt anzunehmen, du dientest allen.',
  },
  {
    num: '09',
    title: 'Wachstum messen, nicht Aufmerksamkeit',
    body: 'Im Digitalen lässt sich vieles leicht messen — aber nicht alles, was sich zählen lässt, sollte gezählt werden, und nicht alles, worauf es ankommt, lässt sich zählen. Geistliches Wachstum entzieht sich dem Messen. Bei passiven Inhalten ist das besonders schwer; bei interaktiven Werkzeugen machen Eingaben der Nutzer manche Anhaltspunkte möglich. So oder so gilt: Sei dir über das Ziel im Klaren — geistliches Wachstum — und sei ehrlich, dass es sich immer nur teilweise in Daten fassen lässt. Achte eher auf Tiefe und Freiheit als auf täglich aktive Nutzer und Tagesserien, und bleibe vorsichtig, dich zu einseitig auf das zu verlassen, was die Zahlen zeigen.',
  },
];

const questions = [
  'Dient das dem Wachstum im Glauben oder nur den Nutzungszahlen?',
  'Freiheit oder Angst?',
  'Übersteht die Motivation des Menschen das Entfernen der Funktion?',
  'Achtet das die Würde und die Selbstbestimmung des Menschen?',
  'Wenn Menschen eine tiefe Gemeinschaft mit Gott entwickelten und die Anwendung nicht mehr bräuchten — würden wir das feiern oder betrauern?',
  'Wenn ein Mensch ein geistlich dürres Jahr hätte — würde er sich willkommen geheißen oder verurteilt fühlen?',
];

const tensions = [
  {
    title: 'Zugänglichkeit vs. Konsum-Spiritualität',
    body: 'Inhalte und Funktionen sollen leicht zugänglich sein und niedrigschwellig einladen — und genau diese Leichtigkeit birgt die Gefahr einer Konsum-Spiritualität, in der Glaube zur Ware wird, die man nach Bedarf bezieht. Die Antwort liegt nicht darin, die Hürden wieder zu erhöhen, sondern zugängliche Angebote in der Tradition, in der Tiefe der Quellen und in einem ehrlichen Ruf zur Nachfolge zu verankern.',
  },
  {
    title: 'Gemeinschaft vs. individuell anfangen',
    body: 'Glaube lebt in Gemeinschaft, und eine Anwendung darf die Gemeinde niemals ersetzen. Zugleich beginnen viele Menschen ihren Weg allein — sie gehören noch zu keiner Gemeinschaft und lassen sich in keine hineindrängen. Es braucht Brücken, die zur Gemeinschaft einladen, statt sie zur Eintrittsbedingung zu machen.',
  },
  {
    title: 'Rhythmus vs. Druck',
    body: 'Ein geistliches Leben braucht Rhythmus und regelmäßige Übung. Doch sobald dieser Rhythmus zur erzwungenen Erwartung wird, schlägt er in Druck und Schuld um. Es gilt, zu einem Rhythmus einzuladen, ohne für eine Unterbrechung zu bestrafen.',
  },
];
---

<BaseLayout lang="de" title="Das Rahmenwerk">
  <!-- Hero -->
  <section class="hero" style="min-height: 60vh;">
    <div class="hero-label">Missional by Design · Das Rahmenwerk</div>
    <h1>Neun<br/>Prinzipien.</h1>
    <p class="hero-subtitle">
      Ein Rahmenwerk für die Entwicklung von Technologie, die dem menschlichen Gedeihen durch geistliche Prägung dient.
      Jedes Prinzip ist aus über 195 Quellen aus Theologie, Verhaltenswissenschaft und Produktgestaltung entstanden.
    </p>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="container">
      <div style="max-width: 70ch;">
        {principles.map((p) => (
          <article class="principle">
            <span class="principle-number">{p.num}</span>
            <h3>{p.title}</h3>
            <p class="lead">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Tensions -->
  <section class="section section-cream">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Spannungen</div>
        <h2>Drei Dinge,<br/>die es auszuhalten gilt.</h2>
        <p class="lead" style="margin-top: 2rem;">
          Das Rahmenwerk löst nicht jede Spannung auf — manche müssen ausgehalten, nicht gelöst werden.
        </p>
      </div>

      <div class="grid grid-3">
        {tensions.map((t) => (
          <div style="padding: 2rem; background: var(--color-white); border: 1px solid var(--color-black);">
            <h4 style="margin-bottom: 1rem;">{t.title}</h4>
            <p style="font-size: 0.95rem; line-height: 1.5;">{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section-ink">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Sechs Fragen</div>
        <h2>Diagnostische<br/>Fragen.</h2>
        <p class="lead" style="margin-top: 2rem; opacity: 0.85;">
          Damit lässt sich jede Funktion, jede Kampagne und jede Gestaltungsentscheidung prüfen, bevor sie veröffentlicht wird.
        </p>
      </div>

      <div>
        {questions.map((q, i) => (
          <div class="question">
            <div class="question-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="question-text">{q}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div style="max-width: 60ch;">
        <h2>Willst du das<br/>Rahmenwerk anwenden?</h2>
        <p class="lead" style="margin-top: 2rem;">
          Das Rahmenwerk ist offen veröffentlicht — als Ressource für die Fachwelt. Wenn du Technologie für geistliche
          Prägung entwickelst — oder allgemeiner für menschliches Gedeihen —, würde ich gern von dir hören.
        </p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <EmailLink label="Kontakt aufnehmen" class="button" />
          <a href={`${base}/de/about`} class="button" style="background: transparent; color: var(--color-black); border: 1px solid var(--color-black);">Über den Autor</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
