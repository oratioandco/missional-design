---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailLink from '../../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const principles = [
  {
    num: '01',
    title: 'Für tatsächliche Nutzungsmuster gestalten',
    body: 'Beiläufige und aufnehmende Formen zuerst — nicht ein angenommenes vertieftes Studium. Die vorherrschende Form ist reaktiv, situativ und kurz. Audio ist das am schnellsten wachsende Format. Lesepläne scheitern an einer Abbruchquote von 50 %. Eine Anwendung der nächsten Generation muss beiläufige und aufnehmende Nutzung zu vollwertigen Bestandteilen machen.',
  },
  {
    num: '02',
    title: 'Vielgestaltige Prägung',
    body: 'Audio, Musik, kontemplative Stille und angeleitete Übung als Hauptformate — nicht als Ergänzung zum Lesen. Die christliche Tradition hat immer durch vielerlei Formen geprägt; digitale Werkzeuge sollten diese Bandbreite zurückgewinnen.',
  },
  {
    num: '03',
    title: 'Der Vermarktung des Geistlichen widerstehen',
    body: 'Transparente Herkunft der Traditionen, Tiefe statt Stöbern, gemeinschaftliche Verbindlichkeit. Traditionen benennen (ignatianisch, benediktinisch, franziskanisch, orthodox). Zur längeren Treue zu einer einzelnen Übung ermutigen statt zum täglichen Hineinschnuppern.',
  },
  {
    num: '04',
    title: 'Sowohl gemeinschaftliche als auch persönliche Prägung fördern',
    body: 'Für gemeinsame Teilhabe und sozialen Zusammenhang gestalten. Persönliche Übung ohne Anbindung an Gemeinschaft droht zum Konsum zu werden. Strukturelle Anstöße zu gemeinschaftlicher Teilhabe wirken der Neigung zur Privatisierung entgegen.',
  },
  {
    num: '05',
    title: 'Brücken zur Gemeinschaft bauen, ohne sie zur Bedingung zu machen',
    body: 'Suchenden Menschen kann man nicht einfach sagen, sie sollten „eine Gemeinde finden"; baue Brücken, schaffe keine Vorbedingungen. Allein beginnen, einen geistlichen Rhythmus entwickeln, dann zu leibhaftiger Gemeinschaft hinwachsen.',
  },
  {
    num: '06',
    title: 'Durchgehend gnadenbasierte Mechanismen',
    body: 'Keine voreingestellten Tagesserien, keine Scham-Auslöser, kein sozialer Vergleich. Verbindlichkeit nur mit Zustimmung. Die ethische Grenze ist die Einwilligung: Der Mensch wählt Werkzeuge für die eigene Prägung — nicht die Plattform setzt Mechanismen für die eigene Nutzerbindung ein. Die leitende Frage: Dient das der Freiheit oder der Furcht? Der Gnade oder der Schuld? Der Prägung oder den Kennzahlen?',
  },
  {
    num: '07',
    title: 'Auf Europa zugeschnittene Voreinstellungen',
    body: 'Eine von Grund auf datenschutzfreundliche Architektur, Gastfreundschaft gegenüber mehreren Traditionen, nachchristliche Grundannahmen, die Datenschutz-Grundverordnung als Bekenntnis zur Würde. Eine europäische geistliche Anwendung kann ein amerikanisches Produkt nicht einfach unverändert übernehmen.',
  },
  {
    num: '08',
    title: 'Den geistlich Suchenden dienen',
    body: 'Durch persönliche Begleitung führen, nicht durch überwältigende Bibliotheken. Der suchende Mensch, der fragt „Wo fange ich an?", braucht eine Begleitung, die zuhört — keinen Katalog, der durchsucht.',
  },
  {
    num: '09',
    title: 'Prägungs-Kennzahlen statt Aufmerksamkeits-Kennzahlen',
    body: 'Tiefe und Freiheit messen — nicht täglich aktive Nutzer und abgeschlossene Tagesserien. Wenn die Anwendung dem Wachstum nicht dient, kündigen die Menschen — und genau das ist der Sinn.',
  },
];

const questions = [
  'Dient das der Prägung oder den Aufmerksamkeits-Kennzahlen?',
  'Freiheit oder Angst?',
  'Übersteht die Motivation des Menschen das Entfernen der Funktion?',
  'Achtet das die Würde und die Selbstbestimmung des Menschen?',
  'Wenn Menschen eine tiefe Gemeinschaft mit Gott entwickelten und die Anwendung nicht mehr bräuchten — würden wir das feiern oder betrauern?',
  'Wenn ein Mensch ein geistlich dürres Jahr hätte — würde er sich willkommen geheißen oder verurteilt fühlen?',
];

const tensions = [
  {
    title: 'Kurze Nutzung vs. Vermarktung',
    body: 'Beiläufige Formen entsprechen echten Nutzungsmustern, drohen die Prägung aber auf einen Nachrichtenstrom zu verkürzen. Die Auflösung: beiläufige Funktionen, die die Tradition benennen, die Tiefe der Quelle und die Treue zur Übung.',
  },
  {
    title: 'Gemeinschaft als Pflicht vs. die Wirklichkeit der Suchenden',
    body: 'Prägung ist gemeinschaftlich, doch viele Menschen sind an keine leibhaftige Gemeinschaft angebunden und lassen sich nicht dazu zwingen. Die Auflösung: Brücken bauen, die einladen, statt Hürden zu errichten.',
  },
  {
    title: 'Regelmäßige Übung vs. Gestaltung gegen Tagesserien',
    body: 'Prägung braucht Gewohnheit, doch Tagesserien-Mechanismen wenden die Gewohnheit gegen den Menschen. Die Auflösung: Einladungen zu einem Rhythmus ohne Bestrafung für Unterbrechungen.',
  },
];
---

<BaseLayout lang="de" title="Das Rahmenwerk">
  <!-- Hero -->
  <section class="hero" style="min-height: 60vh;">
    <div class="hero-label">Missional by Design · Das Rahmenwerk</div>
    <h1>Neun<br/>Prinzipien.</h1>
    <p class="hero-subtitle">
      Ein Rahmenwerk für die Entwicklung von Technologie, die dem menschlichen Gedeihen durch geistliche Prägung dient.
      Jedes Prinzip ist aus über 195 Quellen aus Theologie, Verhaltenswissenschaft und Produktgestaltung entstanden.
    </p>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="container">
      <div style="max-width: 70ch;">
        {principles.map((p) => (
          <article class="principle">
            <span class="principle-number">{p.num}</span>
            <h3>{p.title}</h3>
            <p class="lead">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Tensions -->
  <section class="section section-cream">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Spannungen</div>
        <h2>Drei Dinge,<br/>die es auszuhalten gilt.</h2>
        <p class="lead" style="margin-top: 2rem;">
          Das Rahmenwerk löst nicht jede Spannung auf — manche müssen ausgehalten, nicht gelöst werden.
        </p>
      </div>

      <div class="grid grid-3">
        {tensions.map((t) => (
          <div style="padding: 2rem; background: var(--color-white); border: 1px solid var(--color-black);">
            <h4 style="margin-bottom: 1rem;">{t.title}</h4>
            <p style="font-size: 0.95rem; line-height: 1.5;">{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section-ink">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Sechs Fragen</div>
        <h2>Diagnostische<br/>Fragen.</h2>
        <p class="lead" style="margin-top: 2rem; opacity: 0.85;">
          Damit lässt sich jede Funktion, jede Kampagne und jede Gestaltungsentscheidung prüfen, bevor sie veröffentlicht wird.
        </p>
      </div>

      <div>
        {questions.map((q, i) => (
          <div class="question">
            <div class="question-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="question-text">{q}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div style="max-width: 60ch;">
        <h2>Willst du das<br/>Rahmenwerk anwenden?</h2>
        <p class="lead" style="margin-top: 2rem;">
          Das Rahmenwerk ist offen veröffentlicht — als Ressource für die Fachwelt. Wenn du Technologie für geistliche
          Prägung entwickelst — oder allgemeiner für menschliches Gedeihen —, würde ich gern von dir hören.
        </p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <EmailLink label="Kontakt aufnehmen" class="button" />
          <a href={`${base}/de/about`} class="button" style="background: transparent; color: var(--color-black); border: 1px solid var(--color-black);">Über den Autor</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
