---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailLink from '../../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// NOTE: Draft German copy — please review before going live.
---

<BaseLayout
  lang="de"
  title="Über mich"
  description="Tobias Treppmann — Produktgestalter, Theologe und Gründer von Oratio&Co"
>
  <section class="hero" style="min-height: 50vh;">
    <div class="hero-label">Über mich</div>
    <h1>Über mich.</h1>
  </section>

  <section class="section">
    <div class="container-narrow">
      <p class="lead">
        <strong>Tobias Treppmann</strong> ist Produktgestalter, Theologe und Gründer von Oratio&Co.
        Er verfolgt derzeit einen M.A. in Leitung an der Kairos University, während er
        <a href="https://aperto.bible">Aperto</a> entwickelt — eine Plattform für digitale geistliche Prägung.
      </p>
      <p class="lead">
        Das Rahmenwerk für missionale Produktgestaltung entstand aus seiner Forschungsarbeit von 2026,
        <em>Digital Spiritual Formation: The Aperto Vision</em>, die auf über 195 Quellen aus Theologie,
        Verhaltenswissenschaft und Produktgestaltung aufbaut.
      </p>
      <p class="lead">
        Dieses Rahmenwerk ist offen veröffentlicht — als Ressource für die Fachwelt. Wenn du Technologie für
        geistliche Prägung entwickelst — oder allgemeiner für menschliches Gedeihen —, würde ich gern von dir hören.
      </p>

      <div style="margin-top: 3rem; padding-top: 3rem; border-top: 1px solid var(--color-black);">
        <h3 style="margin-bottom: 1.5rem;">Nimm Kontakt auf</h3>
        <ul style="list-style: none; padding: 0; line-height: 2.5;">
          <li><strong>Kontakt:</strong> <EmailLink label="E-Mail schreiben" /></li>
          <li><strong>Beratung:</strong> <a href="https://oratio.co">oratio.co</a></li>
          <li><strong>Derzeit in Entwicklung:</strong> <a href="https://aperto.bible">aperto.bible</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
