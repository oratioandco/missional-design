---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang="de" title="Texte">
  <section class="hero" style="min-height: 50vh;">
    <div class="hero-label">Missional by Design · Texte</div>
    <h1>Texte.</h1>
    <p class="hero-subtitle">
      Essays über missionale Gestaltung, digitale Prägung, Innovation in der Gemeindearbeit und die überraschende Überschneidung
      zwischen Gemeinden und Gründungen. Impulse aus der Praxis, nicht aus dem Seminarraum.
    </p>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 900px;">
        <!-- Veröffentlichter Beitrag -->
        <a href={`${base}/de/blog/churches-and-startups`} class="post-card">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay</span>
            <span class="post-card-date">2026</span>
          </div>
          <h2 class="post-card-title">Warum Gemeinden und junge Unternehmen mehr gemeinsam haben, als man denkt.</h2>
          <p class="post-card-excerpt">
            Große Vision, knappe Mittel, fließender Kontext. Die überraschende Überschneidung zweier scheinbar
            gegensätzlicher Welten — und was beide voneinander lernen können.
          </p>
          <div class="post-card-read">Essay lesen →</div>
        </a>

        <!-- Demnächst-Platzhalter -->
        <div class="post-card post-card-placeholder">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay · Demnächst</span>
          </div>
          <h3 class="post-card-title">Jede Gemeinde hat ein Design — ob du es weißt oder nicht.</h3>
          <p class="post-card-excerpt">
            Was diese Provokation für Gemeinden bedeutet, die mit kulturellem Wandel umgehen — und warum
            unbewusste Gestaltung meist schlechter ist als bewusste.
          </p>
        </div>

        <div class="post-card post-card-placeholder">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay · Demnächst</span>
          </div>
          <h3 class="post-card-title">Aufmerksamkeits-Kennzahlen sind die falsche Frage.</h3>
          <p class="post-card-excerpt">
            Was wir beim Bau von Aperto gelernt haben: täglich aktive Nutzer sind das falsche Ziel für ein Werkzeug
            der geistlichen Prägung. Worauf es stattdessen ankommt.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .post-card {
    display: block;
    padding: 3rem 0;
    border-top: 1px solid var(--color-black);
    text-decoration: none;
    color: var(--color-black);
    transition: opacity var(--transition);
  }
  .post-card:last-of-type {
    border-bottom: 1px solid var(--color-black);
  }
  .post-card:hover {
    opacity: 0.7;
  }
  .post-card-placeholder {
    opacity: 0.45;
    pointer-events: none;
  }
  .post-card-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .post-card-tag {
    opacity: 0.6;
  }
  .post-card-date {
    opacity: 0.4;
  }
  .post-card-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    max-width: 22ch;
  }
  .post-card-excerpt {
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.5;
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }
  .post-card-read {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
