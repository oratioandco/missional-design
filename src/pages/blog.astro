---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Writing">
  <section class="hero" style="min-height: 50vh;">
    <div class="hero-label">Missional Design · Writing</div>
    <h1>Writing.</h1>
    <p class="hero-subtitle">
      Reflections on missional design, digital formation, and building technology for human flourishing.
    </p>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2" style="max-width: 900px;">
        <article style="padding: 2rem; background: var(--color-cream); border: 1px solid var(--color-black);">
          <div style="font-family: var(--font-display); font-weight: 900; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; margin-bottom: 1rem;">Coming Soon</div>
          <h3>The Ministry Model Canvas</h3>
          <p style="font-size: 0.95rem;">A strategic planning framework for churches, adapted from the Business Model Canvas for ministry contexts.</p>
        </article>
        <article style="padding: 2rem; background: var(--color-cream); border: 1px solid var(--color-black);">
          <div style="font-family: var(--font-display); font-weight: 900; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; margin-bottom: 1rem;">Coming Soon</div>
          <h3>Why churches and startups have more in common than you think</h3>
          <p style="font-size: 0.95rem;">Grand vision, limited resources, fluid context — the similarities between two seemingly opposite worlds, and what each can learn from the other.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
