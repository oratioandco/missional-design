---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang="en" title="Writing">
  <section class="hero" style="min-height: 50vh;">
    <div class="hero-label">Missional by Design · Writing</div>
    <h1>Writing.</h1>
    <p class="hero-subtitle">
      Essays on missional design, digital formation, ministry innovation, and the surprising overlap between churches and
      startups. Thought leadership from the field, not the seminar room.
    </p>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 900px;">
        <!-- Published post -->
        <a href={`${base}/blog/churches-and-startups`} class="post-card">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay</span>
            <span class="post-card-date">2026</span>
          </div>
          <h2 class="post-card-title">Why churches and startups have more in common than you think.</h2>
          <p class="post-card-excerpt">
            Grand vision, limited resources, fluid context. The surprising overlap between two seemingly opposite worlds — and
            what each can learn from the other.
          </p>
          <div class="post-card-read">Read the essay →</div>
        </a>

        <!-- Coming soon placeholders -->
        <div class="post-card post-card-placeholder">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay · Coming soon</span>
          </div>
          <h3 class="post-card-title">All ministry is designed — whether you know it or not.</h3>
          <p class="post-card-excerpt">
            What Tyler Prieb's provocation means for churches navigating cultural drift, and why accidental design is usually
            worse than intentional design.
          </p>
        </div>

        <div class="post-card post-card-placeholder">
          <div class="post-card-meta">
            <span class="post-card-tag">Essay · Coming soon</span>
          </div>
          <h3 class="post-card-title">Engagement metrics are the wrong question.</h3>
          <p class="post-card-excerpt">
            What we learned building Aperto: daily active users are the wrong target for a formation product. Here's what to
            measure instead.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .post-card {
    display: block;
    padding: 3rem 0;
    border-top: 1px solid var(--color-black);
    text-decoration: none;
    color: var(--color-black);
    transition: opacity var(--transition);
  }
  .post-card:last-of-type {
    border-bottom: 1px solid var(--color-black);
  }
  .post-card:hover {
    opacity: 0.7;
  }
  .post-card-placeholder {
    opacity: 0.45;
    pointer-events: none;
  }
  .post-card-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .post-card-tag {
    opacity: 0.6;
  }
  .post-card-date {
    opacity: 0.4;
  }
  .post-card-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    max-width: 22ch;
  }
  .post-card-excerpt {
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.5;
    max-width: 60ch;
    margin-bottom: 1.25rem;
  }
  .post-card-read {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
