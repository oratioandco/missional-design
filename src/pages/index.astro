---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Missional Design">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-label">A framework by Tobias Treppmann · 2026</div>
    <h1>Missional<br/>Design.</h1>
    <p class="hero-subtitle">
      Evidence-based principles for building technology that serves human flourishing — through spiritual formation,
      ministry innovation, and product decisions that honor the people who use them.
    </p>
    <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href={`${base}/framework`} class="button">Read the Framework</a>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="section section-cream">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 70ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">The Manifesto</div>
        <h2>Four values<br/>we choose first.</h2>
        <p class="lead" style="margin-top: 2rem;">
          We build digital tools for spiritual formation — and have learned that what serves formation also produces
          better products. While the items on the right sustain businesses and serve users, we choose the items on
          the left first when the two conflict.
        </p>
      </div>

      <div class="manifesto-values">
        <div class="left">Formation</div>
        <div class="sep">over</div>
        <div class="right">Engagement</div>

        <div class="left">Partnership</div>
        <div class="sep">over</div>
        <div class="right">Persuasion</div>

        <div class="left">Challenge</div>
        <div class="sep">over</div>
        <div class="right">Comfort</div>

        <div class="left">Community</div>
        <div class="sep">over</div>
        <div class="right">Platform</div>
      </div>
    </div>
  </section>

  <!-- Nine Principles -->
  <section class="section section-dark">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Nine Principles</div>
        <h2>How we build<br/>for formation.</h2>
      </div>

      <div class="grid grid-3">
        <div class="principle">
          <span class="principle-number">01</span>
          <h4>Design for actual engagement patterns</h4>
          <p>Ambient and receptive modes first, not assumed deep study.</p>
        </div>
        <div class="principle">
          <span class="principle-number">02</span>
          <h4>Multimodal formation</h4>
          <p>Audio, music, and guided practice as primary formats, not supplements.</p>
        </div>
        <div class="principle">
          <span class="principle-number">03</span>
          <h4>Resist spiritual commodification</h4>
          <p>Transparent tradition sourcing, depth over browsing, communal accountability.</p>
        </div>
        <div class="principle">
          <span class="principle-number">04</span>
          <h4>Serve communal as well as individual formation</h4>
          <p>Design for shared engagement and social context.</p>
        </div>
        <div class="principle">
          <span class="principle-number">05</span>
          <h4>Scaffold toward community without requiring it</h4>
          <p>Build bridges for the liminal, don't create prerequisites.</p>
        </div>
        <div class="principle">
          <span class="principle-number">06</span>
          <h4>Grace-based mechanics throughout</h4>
          <p>No default streaks, shame triggers, or social comparison. Opt-in accountability only.</p>
        </div>
        <div class="principle">
          <span class="principle-number">07</span>
          <h4>European-specific defaults</h4>
          <p>Privacy-first architecture, multi-tradition hospitality, post-Christian assumptions.</p>
        </div>
        <div class="principle">
          <span class="principle-number">08</span>
          <h4>Serve the spiritually liminal</h4>
          <p>Personalized companionship, not overwhelming libraries.</p>
        </div>
        <div class="principle">
          <span class="principle-number">09</span>
          <h4>Formation metrics over engagement metrics</h4>
          <p>Measure depth and freedom — not daily active users.</p>
        </div>
      </div>

      <div style="margin-top: 4rem;">
        <a href={`${base}/framework`} class="button">Read each principle in full</a>
      </div>
    </div>
  </section>

  <!-- Six Questions -->
  <section class="section section-ink">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Six Questions</div>
        <h2>Ask these<br/>before you ship.</h2>
        <p class="lead" style="margin-top: 2rem; opacity: 0.85;">
          Diagnostic questions to help teams evaluate whether their features serve formation or engagement.
        </p>
      </div>

      <div>
        <div class="question">
          <div class="question-number">01</div>
          <div class="question-text">Does this serve formation or engagement metrics?</div>
        </div>
        <div class="question">
          <div class="question-number">02</div>
          <div class="question-text">Freedom or anxiety?</div>
        </div>
        <div class="question">
          <div class="question-number">03</div>
          <div class="question-text">Will the user's motivation survive removing the feature?</div>
        </div>
        <div class="question">
          <div class="question-number">04</div>
          <div class="question-text">Does this honor human dignity and agency?</div>
        </div>
        <div class="question">
          <div class="question-number">05</div>
          <div class="question-text">If users developed deep communion with God and no longer needed the app, would we celebrate or mourn?</div>
        </div>
        <div class="question">
          <div class="question-number">06</div>
          <div class="question-text">If a user had a spiritually dry year, would they feel welcomed back or judged?</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ministry Model Canvas -->
  <section class="section section-cream">
    <div class="container">
      <div class="grid grid-2" style="align-items: center; gap: 4rem;">
        <div>
          <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Also: The Canvas</div>
          <h2>Ministry<br/>Model Canvas.</h2>
          <p class="lead" style="margin-top: 2rem;">
            A nine-block strategic planning framework for churches — adapted from the Business Model Canvas to help teams clarify
            their mission, name their target audience, and design toward missional effectiveness.
          </p>
          <div style="margin-top: 2rem;">
            <a href={`${base}/ministry-model-canvas`} class="button">Explore the canvas</a>
          </div>
        </div>
        <div style="border: 1px solid var(--color-black); padding: 0; background: var(--color-white); display: grid; grid-template-columns: repeat(5, 1fr); aspect-ratio: 5/3; font-family: var(--font-display); font-weight: 900; font-size: 0.65rem; letter-spacing: -0.01em;">
          <div style="grid-column: 1; grid-row: 1/3; padding: 0.75rem; border-right: 1px solid var(--color-black); display: flex; align-items: flex-start;">Connecting<br/>Factor</div>
          <div style="grid-column: 2; grid-row: 1; padding: 0.75rem; border-right: 1px solid var(--color-black); border-bottom: 1px solid var(--color-black);">Key<br/>Activities</div>
          <div style="grid-column: 2; grid-row: 2; padding: 0.75rem; border-right: 1px solid var(--color-black);">Resources</div>
          <div style="grid-column: 3; grid-row: 1/3; padding: 0.75rem; border-right: 1px solid var(--color-black); display: flex; align-items: flex-start;">Missional<br/>Identity</div>
          <div style="grid-column: 4; grid-row: 1; padding: 0.75rem; border-right: 1px solid var(--color-black); border-bottom: 1px solid var(--color-black);">Relation-<br/>ships</div>
          <div style="grid-column: 4; grid-row: 2; padding: 0.75rem; border-right: 1px solid var(--color-black);">Channels</div>
          <div style="grid-column: 5; grid-row: 1/3; padding: 0.75rem; display: flex; align-items: flex-start;">Target<br/>Audience</div>
          <div style="grid-column: 1/3; grid-row: 3; padding: 0.75rem; border-top: 1px solid var(--color-black); border-right: 1px solid var(--color-black);">Budget</div>
          <div style="grid-column: 3/6; grid-row: 3; padding: 0.75rem; border-top: 1px solid var(--color-black);">Assessing Missional Effectiveness</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Work with us / services -->
  <section class="section">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Work With Us</div>
        <h2>Put the framework<br/>to work.</h2>
      </div>

      <div class="grid grid-3">
        <div style="padding: 2rem; background: var(--color-cream); border: 1px solid var(--color-black);">
          <div style="font-family: var(--font-display); font-weight: 900; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem;">01 · Consultation</div>
          <h4>Ministry Consultation</h4>
          <p>Personalized consultation to help your ministry navigate the challenges of building effective, faithful technology in the 21st century.</p>
        </div>
        <div style="padding: 2rem; background: var(--color-cream); border: 1px solid var(--color-black);">
          <div style="font-family: var(--font-display); font-weight: 900; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem;">02 · Training</div>
          <h4>Innovation Training</h4>
          <p>Equipping your team with the skills and frameworks to implement innovative, formation-centered strategies in your ministry or product.</p>
        </div>
        <div style="padding: 2rem; background: var(--color-cream); border: 1px solid var(--color-black);">
          <div style="font-family: var(--font-display); font-weight: 900; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem;">03 · Cohort</div>
          <h4>Online Ministry Innovation Cohort</h4>
          <p>Join a community of practitioners working at the intersection of faith, design, and technology — sharing experience and learning together.</p>
        </div>
      </div>

      <div style="margin-top: 3rem;">
        <a href="mailto:hello@treppmann.design" class="button">Get in touch</a>
      </div>
    </div>
  </section>
</BaseLayout>
