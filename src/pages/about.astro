---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailLink from '../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="About">
  <section class="hero" style="min-height: 50vh;">
    <div class="hero-label">About</div>
    <h1>About.</h1>
  </section>

  <section class="section">
    <div class="container-narrow">
      <p class="lead">
        <strong>Tobias Treppmann</strong> is a product designer, theologian, and founder of Oratio&Co.
        He is currently pursuing an M.A. in Leadership at Kairos University while building
        <a href="https://aperto.bible">Aperto</a>, a digital spiritual formation platform.
      </p>
      <p class="lead">
        The missional product design framework emerged from his 2026 research paper
        <em>Digital Spiritual Formation: The Aperto Vision</em>, which draws on 195+ sources across theology,
        behavioral science, and product design.
      </p>
      <p class="lead">
        This framework is published openly as a resource for the field. If you're building technology for
        spiritual formation — or human flourishing more broadly — I'd love to hear from you.
      </p>

      <div style="margin-top: 3rem; padding-top: 3rem; border-top: 1px solid var(--color-black);">
        <h3 style="margin-bottom: 1.5rem;">Get in touch</h3>
        <ul style="list-style: none; padding: 0; line-height: 2.5;">
          <li><strong>Email:</strong> <EmailLink /></li>
          <li><strong>Consulting:</strong> <a href="https://oratio.co">oratio.co</a></li>
          <li><strong>Currently building:</strong> <a href="https://aperto.bible">aperto.bible</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
