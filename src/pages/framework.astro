---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailLink from '../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const principles = [
  {
    num: '01',
    title: 'Design for actual behavior, not imposed expectations',
    body: 'Ambient and receptive modes first, not assumed deep study. The dominant mode is reactive, situational, and brief. Audio is the fastest-growing format. Reading plans fail at 50% dropout. A next-generation app must make ambient and receptive engagement first-class citizens. This calls for humility toward how people actually behave, instead of imposing expectations on them.',
  },
  {
    num: '02',
    title: 'Open different ways to faith',
    body: 'Audio, music, contemplative silence, and guided practice as primary formats — not supplements to reading. Bible reading is not the single highest spiritual practice. People come to faith through genuinely different doorways; good design recognizes that breadth — including ecumenical breadth — and supports people in it. The Christian tradition has always known this range.',
  },
  {
    num: '03',
    title: 'Resist consumer spirituality',
    body: 'Genuine engagement with tradition, not a feel-good spiritual buffet. Be transparent about where a practice comes from; depth over browsing; communal accountability. Name the traditions (Ignatian, Benedictine, Franciscan, Orthodox). Encourage sustained commitment to a single practice rather than daily sampling — no echo chambers, no pick-and-mix spirituality.',
  },
  {
    num: '04',
    title: 'Never a substitute for church and community',
    body: "Faith is not private; it is lived in community. A spiritual app must never become a substitute for the church and for real fellowship. That does not mean it has to add 'community features' — it means it must not pull people into filter bubbles and self-isolation. Practice cut off from a body of people drifts toward consumerism; design should keep pointing back to embodied community.",
  },
  {
    num: '05',
    title: 'Build bridges to community without requiring it',
    body: "People who are spiritually searching cannot simply be told to 'find a church.' Build bridges, don't set prerequisites. Someone can begin alone, find a spiritual rhythm, and grow from there toward embodied community. The goal is always real fellowship — the app is the bridge, never the destination.",
  },
  {
    num: '06',
    title: 'Grace and freedom, not pressure and guilt',
    body: "This is a deliberate reaction against gamification, performance spirituality, and other engagement mechanics imposed on people unasked. Streaks, shame triggers, social comparison — they produce pressure and guilt, not the grace and freedom Christ promises. Even a reading plan that expects daily reading and then tells someone they have 'fallen behind' does exactly this. Hold one line: the user chooses tools for their own growth; the platform never deploys mechanics for its own retention. And trust the content — what is genuinely relevant needs no artificial reinforcement to keep people coming back.",
  },
  {
    num: '07',
    title: 'Design from context, not borrowed patterns',
    body: "Don't blindly adopt the mechanics and assumptions of Silicon Valley, or of whatever apps happen to be dominant. Engage seriously and concretely with your own audience and the context they live in. Europe is one example: patterns taken for granted in American products — around privacy, around a post-Christian culture, around what a user is assumed to want — often matter far less here. Privacy-first architecture, hospitality to many traditions, GDPR as a commitment to dignity. But that is the example, not the principle. The principle is that context is never optional.",
  },
  {
    num: '08',
    title: 'Know honestly whom you serve',
    body: "This, too, takes reflection. Which people, at which point on their Christian journey, do you actually help? It does not mean serving only seekers or skeptics. It means being concrete — and honestly transparent — about two things: whom you intend to reach, and whom your current content and features can in fact reach. People stand in very different spiritual situations; name yours, rather than assuming you serve everyone.",
  },
  {
    num: '09',
    title: 'Measure growth, not engagement',
    body: "In digital products, a great deal is easy to measure — but not everything that can be counted should be, and not everything that matters can be counted. Spiritual growth resists measurement. With passive content this is especially hard; with interactive tools, user input makes some signal possible. Either way, be clear about the goal — spiritual growth — and be honest that it can only ever be partly captured in data. Pay attention to depth and freedom rather than daily active users and streaks, and stay wary of leaning too one-sidedly on what the numbers show.",
  },
];

const questions = [
  'Does this serve formation or engagement metrics?',
  'Freedom or anxiety?',
  "Will the user's motivation survive removing the feature?",
  'Does this honor human dignity and agency?',
  'If users developed deep communion with God and no longer needed the app, would we celebrate or mourn?',
  'If a user had a spiritually dry year, would they feel welcomed back or judged?',
];

const tensions = [
  {
    title: 'Brief engagement vs. commodification',
    body: 'Ambient modes serve real engagement patterns, but risk reducing formation to a feed. The resolution: ambient features that name the tradition, depth of source, and commitment to practice.',
  },
  {
    title: 'Community requirement vs. liminal reality',
    body: 'Formation is communal, but many users are not connected to embodied community and cannot be coerced into it. The resolution: scaffold bridges that invite rather than gate.',
  },
  {
    title: 'Regular practice vs. anti-streak design',
    body: 'Formation requires habit, but streak mechanics weaponize habit against the user. The resolution: invitations to rhythm without punishment for rupture.',
  },
];
---

<BaseLayout lang="en" title="The Framework">
  <!-- Hero -->
  <section class="hero" style="min-height: 60vh;">
    <div class="hero-label">Missional by Design · The Framework</div>
    <h1>Nine<br/>Principles.</h1>
    <p class="hero-subtitle">
      A framework for building technology that serves human flourishing through spiritual formation.
      Each principle emerged from 195+ sources across theology, behavioral science, and product design.
    </p>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="container">
      <div style="max-width: 70ch;">
        {principles.map((p) => (
          <article class="principle">
            <span class="principle-number">{p.num}</span>
            <h3>{p.title}</h3>
            <p class="lead">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Tensions -->
  <section class="section section-cream">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Tensions</div>
        <h2>Three things<br/>worth holding.</h2>
        <p class="lead" style="margin-top: 2rem;">
          The framework does not resolve every tension — some must be held, not solved.
        </p>
      </div>

      <div class="grid grid-3">
        {tensions.map((t) => (
          <div style="padding: 2rem; background: var(--color-white); border: 1px solid var(--color-black);">
            <h4 style="margin-bottom: 1rem;">{t.title}</h4>
            <p style="font-size: 0.95rem; line-height: 1.5;">{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section-ink">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Six Questions</div>
        <h2>Diagnostic<br/>questions.</h2>
        <p class="lead" style="margin-top: 2rem; opacity: 0.85;">
          Use these to evaluate any feature, campaign, or design decision before it ships.
        </p>
      </div>

      <div>
        {questions.map((q, i) => (
          <div class="question">
            <div class="question-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="question-text">{q}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div style="max-width: 60ch;">
        <h2>Want to apply<br/>the framework?</h2>
        <p class="lead" style="margin-top: 2rem;">
          The framework is published openly as a resource for the field. If you're building technology for spiritual
          formation — or human flourishing more broadly — I'd love to hear from you.
        </p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <EmailLink label="Get in touch" class="button" />
          <a href={`${base}/about`} class="button" style="background: transparent; color: var(--color-black); border: 1px solid var(--color-black);">About the author</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
