---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailLink from '../components/EmailLink.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const principles = [
  {
    num: '01',
    title: 'Design for actual engagement patterns',
    body: 'Ambient and receptive modes first, not assumed deep study. The dominant mode is reactive, situational, and brief. Audio is the fastest-growing format. Reading plans fail at 50% dropout. A next-generation app must make ambient and receptive engagement first-class citizens.',
  },
  {
    num: '02',
    title: 'Multimodal formation',
    body: 'Audio, music, contemplative silence, and guided practice as primary formats, not supplements to reading. The Christian tradition has always formed through multiple modes; digital tools should recover that breadth.',
  },
  {
    num: '03',
    title: 'Resist spiritual commodification',
    body: 'Transparent tradition sourcing, depth over browsing, communal accountability. Name traditions (Ignatian, Benedictine, Franciscan, Orthodox). Encourage commitment to a single practice for sustained periods rather than daily sampling.',
  },
  {
    num: '04',
    title: 'Serve communal as well as individual formation',
    body: 'Design for shared engagement and social context. Individual practice disconnected from community risks consumerism. Structural prompts toward communal engagement counter the privatization tendency.',
  },
  {
    num: '05',
    title: 'Scaffold toward community without requiring it',
    body: 'Liminal users cannot be told to "find a church"; build bridges, don\'t create prerequisites. Begin alone, develop spiritual rhythm, then grow toward embodied community.',
  },
  {
    num: '06',
    title: 'Grace-based mechanics throughout',
    body: 'No default streaks, shame triggers, or social comparison. Opt-in accountability. The ethical line is consent: the user choosing tools for their own formation, not the platform deploying mechanics for its retention. The animating question: does this serve freedom or fear? Grace or guilt? Formation or metrics?',
  },
  {
    num: '07',
    title: 'European-specific defaults',
    body: 'Privacy-first architecture, multi-tradition hospitality, post-Christian assumptions, GDPR as dignity commitment. A European spiritual app cannot localize an American product wholesale.',
  },
  {
    num: '08',
    title: 'Serve the spiritually liminal',
    body: 'Guide through personalized companionship, not overwhelming libraries. The liminal user asking "where do I start?" needs a companion who listens, not a catalog that searches.',
  },
  {
    num: '09',
    title: 'Formation metrics over engagement metrics',
    body: "Measure depth and freedom, not daily active users and streak completions. If the app doesn't serve growth, users cancel — and that's the point.",
  },
];

const questions = [
  'Does this serve formation or engagement metrics?',
  'Freedom or anxiety?',
  "Will the user's motivation survive removing the feature?",
  'Does this honor human dignity and agency?',
  'If users developed deep communion with God and no longer needed the app, would we celebrate or mourn?',
  'If a user had a spiritually dry year, would they feel welcomed back or judged?',
];

const tensions = [
  {
    title: 'Brief engagement vs. commodification',
    body: 'Ambient modes serve real engagement patterns, but risk reducing formation to a feed. The resolution: ambient features that name the tradition, depth of source, and commitment to practice.',
  },
  {
    title: 'Community requirement vs. liminal reality',
    body: 'Formation is communal, but many users are not connected to embodied community and cannot be coerced into it. The resolution: scaffold bridges that invite rather than gate.',
  },
  {
    title: 'Regular practice vs. anti-streak design',
    body: 'Formation requires habit, but streak mechanics weaponize habit against the user. The resolution: invitations to rhythm without punishment for rupture.',
  },
];
---

<BaseLayout title="The Framework">
  <!-- Hero -->
  <section class="hero" style="min-height: 60vh;">
    <div class="hero-label">Missional by Design · The Framework</div>
    <h1>Nine<br/>Principles.</h1>
    <p class="hero-subtitle">
      A framework for building technology that serves human flourishing through spiritual formation.
      Each principle emerged from 195+ sources across theology, behavioral science, and product design.
    </p>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="container">
      <div style="max-width: 70ch;">
        {principles.map((p) => (
          <article class="principle">
            <span class="principle-number">{p.num}</span>
            <h3>{p.title}</h3>
            <p class="lead">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Tensions -->
  <section class="section section-cream">
    <div class="container">
      <div style="margin-bottom: 3rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Tensions</div>
        <h2>Three things<br/>worth holding.</h2>
        <p class="lead" style="margin-top: 2rem;">
          The framework does not resolve every tension — some must be held, not solved.
        </p>
      </div>

      <div class="grid grid-3">
        {tensions.map((t) => (
          <div style="padding: 2rem; background: var(--color-white); border: 1px solid var(--color-black);">
            <h4 style="margin-bottom: 1rem;">{t.title}</h4>
            <p style="font-size: 0.95rem; line-height: 1.5;">{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section-ink">
    <div class="container">
      <div style="margin-bottom: 4rem; max-width: 60ch;">
        <div style="font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem; font-weight: 700; opacity: 0.6;">Six Questions</div>
        <h2>Diagnostic<br/>questions.</h2>
        <p class="lead" style="margin-top: 2rem; opacity: 0.85;">
          Use these to evaluate any feature, campaign, or design decision before it ships.
        </p>
      </div>

      <div>
        {questions.map((q, i) => (
          <div class="question">
            <div class="question-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="question-text">{q}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div style="max-width: 60ch;">
        <h2>Want to apply<br/>the framework?</h2>
        <p class="lead" style="margin-top: 2rem;">
          The framework is published openly as a resource for the field. If you're building technology for spiritual
          formation — or human flourishing more broadly — I'd love to hear from you.
        </p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <EmailLink label="Get in touch" class="button" />
          <a href={`${base}/about`} class="button" style="background: transparent; color: var(--color-black); border: 1px solid var(--color-black);">About the author</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
