---
/**
 * Scraper-resistant email link — hardened.
 * See oratio-co/src/components/EmailLink.astro for full threat model.
 */

interface Props {
  user?: string;
  domain?: string;
  tld?: string;
  label?: string;
  class?: string;
}

const {
  user = 'tobias',
  domain = 'missional',
  tld = 'design',
  label = 'Email',
  class: className = '',
} = Astro.props;

const SALT = 'x7$';
const addr = `${user}@${domain}.${tld}`;
const encoded = Buffer.from(SALT + addr, 'utf-8').toString('base64');
---

<a
  class={`obf-email ${className}`}
  href="#"
  data-x={encoded}
  aria-label={label}
>{label}</a>

<script is:inline>
  (function () {
    var SALT_LEN = 3;
    function reveal(el) {
      var enc = el.getAttribute('data-x');
      if (!enc) return;
      try {
        var decoded = atob(enc);
        if (decoded.length <= SALT_LEN) return;
        var addr = decoded.slice(SALT_LEN);
        el.setAttribute('href', 'mailto:' + addr);
        el.removeAttribute('data-x');
      } catch (e) { /* ignore */ }
    }
    document.querySelectorAll('a.obf-email').forEach(function (el) {
      var once = { once: true };
      el.addEventListener('pointerenter', function () { reveal(el); }, once);
      el.addEventListener('focus',        function () { reveal(el); }, once);
      el.addEventListener('touchstart',   function () { reveal(el); }, { once: true, passive: true });
      el.addEventListener('mousedown',    function () { reveal(el); }, once);
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') reveal(el);
      }, once);
    });
  })();
</script>

<style>
  a.obf-email { cursor: pointer; }
</style>
