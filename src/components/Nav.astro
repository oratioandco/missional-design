<nav class="nav">
  <div class="nav-container">
    <div class="nav-brand">
      <a href="/">Missional Design</a>
    </div>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/framework">Framework</a></li>
      <li><a href="/blog">Writing</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    background-color: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand a {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-brand a:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition);
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .nav-links {
      gap: 1.5rem;
      justify-content: center;
    }

    .nav-links a {
      font-size: 0.95rem;
    }
  }
</style>
